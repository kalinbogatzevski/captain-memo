[Unit]
Description=Captain Memo embedder sidecar (user-level, voyage-4-nano via FastAPI)
After=default.target

[Service]
Type=simple
WorkingDirectory=__INSTALL_DIR__
Environment="PATH=__INSTALL_DIR__/venv/bin:/usr/bin:/bin"
Environment="HF_HOME=__INSTALL_DIR__/models"
ExecStart=__INSTALL_DIR__/venv/bin/uvicorn app:app --host 127.0.0.1 --port 8124 --log-level info
Restart=on-failure
RestartSec=5

[Install]
WantedBy=default.target
